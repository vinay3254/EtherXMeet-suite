# .env.example — copy to .env and fill in values before deploying
# ─────────────────────────────────────────────────────────────────

# Polygon network RPCs
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# Deployer wallet private key (never commit the real .env file!)
PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Polygonscan API key for contract verification (https://polygonscan.com/apis)
POLYGONSCAN_API_KEY=A1HK31NT6XA1V87N7MG27HTNUHZMHY1FS4

# Populated automatically by scripts/deploy.js — also set manually if needed
CONTRACT_ADDRESS=deployed_contract_address_here

# ─── Vite (frontend) env vars ────────────────────────────────────
# These are read by Vite at build time (must start with VITE_)
# NOTE: The deploy script writes the address directly to
#       frontend/src/contracts/MeetingRegistry.json — these VITE_ vars
#       are optional convenience copies for CI or manual overrides.
VITE_CONTRACT_ADDRESS=same_as_CONTRACT_ADDRESS
VITE_POLYGON_RPC_URL=same_as_POLYGON_RPC_URL

# Set to "mainnet" to link ChainBadge tx hashes to polygonscan.com instead of mumbai
VITE_NETWORK=testnet


VITE_100MS_APP_KEY=your_key
VITE_100MS_APP_SECRET=your_secret
VITE_100MS_DEFAULT_ROLE=host
VITE_API_BASE_URL=http://localhost:5000
VITE_MEETING_API_BASE_URL=http://localhost:4000
PORT=3000

# Polygon / Web3
VITE_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
